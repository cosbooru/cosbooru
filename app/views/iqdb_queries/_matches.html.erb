<%# high_similarity_matches, low_similarity_matches, matches %>

<div class="iqdb-posts">
  <h2>Similar Posts</h2>

  <p class="fineprint">
    <% if @high_similarity_matches.blank? %>
      No similar posts found.
    <% end %>

    <% if @low_similarity_matches.present? %>
      <%= link_to "Show #{pluralize(@low_similarity_matches.length, "low similarity match")}", "#", class: "toggle-iqdb-posts-low-similarity" %>
      <%= link_to "Hide #{pluralize(@low_similarity_matches.length, "low similarity match")}", "#", class: "toggle-iqdb-posts-low-similarity", style: "display: none" %>
    <% end %>
  </p>

  <%= render(MediaAssetGalleryComponent.new(size: "180")) do |gallery| %>
    <% @matches.each do |match| %>
      <% media_asset = match["media_asset"] %>
      <% preview_class = match.in?(@high_similarity_matches) ? "iqdb-high-similarity text-center" : "iqdb-low-similarity text-center hidden" %>
      <% link_target = media_asset.post.present? ? post_path(media_asset.post) : media_asset_path(media_asset) %>

      <%= gallery.with_media_asset do %>
        <%= render MediaAssetPreviewComponent.new(media_asset: media_asset, link_target: link_target, classes: preview_class) do |preview| %>
          <% preview.with_footer do %>
            <div class="text-xs text-center mt-1">
              <div>
                <% if media_asset.post.present? %>
                  <%= render "posts/partials/show/preview_source_footer", post: media_asset.post %>
                <% else %>
                  <%= link_to_media_asset media_asset %>
                <% end %>
              </div>

              <div>
                <%= link_to "#{match["score"].round}% similar", iqdb_queries_path(media_asset_id: media_asset.id), class: "inactive-link iqdb-similarity-score" %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
