#!/usr/bin/env bash

# Build a Docker image. Note that uncommited changes won't be included in the
# image; commit changes to Git first before building the image.
#
# This will build two images under `ghcr.io/aibooruorg/aibooru`, one tagged `latest`
# and the other tagged `development`. The development image contains additional tools
# needed to rebuild the JS and CSS files during development.
#
# Usage:
#
#    # Commit any changed files first or they won't be included in the build.
#    $ git commit --all
#
#    # Build images named `cosbooru` and `cosbooru:development`.
#    $ bin/build-docker-image cosbooru
#
#    # Build ARM images named `cosbooru:arm64` and `cosbooru:development-arm64`.
#    # To build ARM images on x86, you must install QEMU first.
#    $ sudo apt-get install qemu-system-arm qemu-user-static binfmt-support
#    $ bin/build-docker-image cosbooru linux/arm64
#
#    # Build multi-architecture images for ARM and x86 named `cosbooru` and `cosbooru:development`.
#    $ bin/build-docker-image cosbooru linux/amd64,linux/arm64
#
#    # Test out the new image.
#    $ DANBOORU_IMAGE=cosbooru:development bin/dev

set -euxo pipefail

ARCH="$(docker info -f '{{ .ClientInfo.Arch }}')"
CURRENT_PLATFORM="linux/$ARCH"

IMAGE="${1:-ghcr.io/cosbooru/cosbooru}"

JOBS="${JOBS:-$(nproc)}"

PLATFORM="${2:-$CURRENT_PLATFORM}"

DOCKER_IMAGE_REVISION=$(git rev-parse HEAD)
DOCKER_IMAGE_BUILD_DATE="$(TZ=UTC git show --no-patch --date=format-local:"%Y-%m-%dT%H:%M:%SZ" --format="%cd" $DOCKER_IMAGE_REVISION)"
SOURCE_DATE_EPOCH=$(git show --no-patch --format=%ct $DOCKER_IMAGE_REVISION)

docker buildx create --use --name nonparallel-builder --config buildkitd.toml 2> /dev/null || true;

if [[ $PLATFORM != $CURRENT_PLATFORM && $PLATFORM != *,* ]]; then
  # If we're building for a different platform, and it's not a multi-platform image, then name the image after the platform so it doesn't conflict with images for the native platform.
  TARGET_ARCH="${PLATFORM#*/}" # linux/arm64 -> arm64
  git archive HEAD | docker buildx build - --platform $PLATFORM --build-arg DOCKER_IMAGE_REVISION=$DOCKER_IMAGE_REVISION --build-arg DOCKER_IMAGE_BUILD_DATE=$DOCKER_IMAGE_BUILD_DATE --build-arg SOURCE_DATE_EPOCH=$SOURCE_DATE_EPOCH --build-arg JOBS=$JOBS --target development --file Dockerfile --output type=docker,name=$IMAGE:development-$TARGET_ARCH,rewrite-timestamp=true
  git archive HEAD | docker buildx build - --platform $PLATFORM --build-arg DOCKER_IMAGE_REVISION=$DOCKER_IMAGE_REVISION --build-arg DOCKER_IMAGE_BUILD_DATE=$DOCKER_IMAGE_BUILD_DATE --build-arg SOURCE_DATE_EPOCH=$SOURCE_DATE_EPOCH --build-arg JOBS=$JOBS --target production  --file Dockerfile --output type=docker,name=$IMAGE:$TARGET_ARCH,rewrite-timestamp=true
else
  git archive HEAD | docker buildx build - --platform $PLATFORM --build-arg DOCKER_IMAGE_REVISION=$DOCKER_IMAGE_REVISION --build-arg DOCKER_IMAGE_BUILD_DATE=$DOCKER_IMAGE_BUILD_DATE --build-arg SOURCE_DATE_EPOCH=$SOURCE_DATE_EPOCH --build-arg JOBS=$JOBS --target development --file Dockerfile --output type=docker,name=$IMAGE:development,rewrite-timestamp=true
  git archive HEAD | docker buildx build - --platform $PLATFORM --build-arg DOCKER_IMAGE_REVISION=$DOCKER_IMAGE_REVISION --build-arg DOCKER_IMAGE_BUILD_DATE=$DOCKER_IMAGE_BUILD_DATE --build-arg SOURCE_DATE_EPOCH=$SOURCE_DATE_EPOCH --build-arg JOBS=$JOBS --target production  --file Dockerfile --output type=docker,name=$IMAGE,rewrite-timestamp=true
fi
